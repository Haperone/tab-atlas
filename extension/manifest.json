{
  "manifest_version": 3,
  "name": "Tab Atlas",
  "version": "1.0.0",
  "description": "A calm new-tab dashboard: your open tabs grouped by domain, searchable, themeable, and organised into folders.",
  "permissions": ["tabs", "activeTab", "storage", "favicon", "tabGroups"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Atlas",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
